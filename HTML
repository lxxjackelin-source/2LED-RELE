<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <style>
    body {
      margin: 0;
      height: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #0f172a;
      font-family: Arial, sans-serif;
      color: white;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 16px;
      width: 230px;
      text-align: center;
    }

    .title {
      color: #38bdf8;
      font-size: 18px;
      margin-bottom: 12px;
    }

    .value {
      font-size: 36px;
      font-weight: bold;
    }

    .unit {
      font-size: 14px;
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="title">📏 Distancia Ultrasónica</div>
    <div class="value">{{ value | number:2 }}</div>
    <div class="unit">cm</div>
  </div>

</body>
</html>
